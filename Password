import re

def check_str(password):
    if len(password) < 8:
        return "Weak: Min 8 characters"

    has_d = any(c.isdigit() for c in password)
    has_u = any(c.isupper() for c in password)
    has_l = any(c.islower() for c in password)
    has_s = bool(re.search(r'[^\w]', password))

    if not has_d:
        return "Weak: Need at least one digit"
    if not has_u:
        return "Weak: Need at least one uppercase letter"
    if not has_l:
        return "Weak: Need at least one lowercase letter"
    if not has_s:
        return "Medium: Need at least one special character"

    return "Strong: Secure password"


while True:
    password = input("\nEnter password (type 'exit' to quit): ")

    if password.lower() == "exit":
        print("Bye")
        break

    print(check_str(password))
